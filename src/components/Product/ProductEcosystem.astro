---
import Title from '../UI/Title.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const managerText = t('product.ecosystem.webPanel');
const [managerTitle, managerDesc] = managerText.includes(':') 
  ? managerText.split(':') 
  : [managerText, ''];

const employeeText = t('product.ecosystem.mobileApp');
const [employeeTitle, employeeDesc] = employeeText.includes(':') 
  ? employeeText.split(':') 
  : [employeeText, ''];
---

<section class="mb-20">
  <div class="text-center mb-12">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] text-sm font-semibold tracking-wide uppercase mb-3">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      <span>{t('product.ecosystem.title')}</span>
    </div>
    <Title as="h2" class="text-3xl font-extrabold text-[var(--color-neutral)] mb-4">
      
    </Title>
    <p class="text-lg text-[var(--color-tertiary)] max-w-2xl mx-auto">
      {t('product.ecosystem.desc')}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
    <!-- Card 1: Managers -->
    <div class="group bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-xl hover:scale-[1.02] hover:border-[var(--color-primary)]/30 transition-all duration-300 flex flex-col justify-between">
      <div>
        <div class="w-14 h-14 rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
        </div>
        <Title as="h3" class="text-2xl font-bold text-[var(--color-neutral)] mb-4">
          {managerTitle.trim()}
        </Title>
        <p class="text-[var(--color-tertiary)] leading-relaxed mb-6">
          {managerDesc.trim()}
        </p>
      </div>
      <div class="border-t border-gray-100 pt-4 text-xs font-semibold text-[var(--color-primary)] uppercase tracking-wider">
        Acceso de Manager
      </div>
    </div>

    <!-- Card 2: Employees -->
    <div class="group bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-xl hover:scale-[1.02] hover:border-[var(--color-primary)]/30 transition-all duration-300 flex flex-col justify-between">
      <div>
        <div class="w-14 h-14 rounded-xl bg-[var(--color-secondary)]/20 text-[var(--color-neutral)] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <Title as="h3" class="text-2xl font-bold text-[var(--color-neutral)] mb-4">
          {employeeTitle.trim()}
        </Title>
        <p class="text-[var(--color-tertiary)] leading-relaxed mb-6">
          {employeeDesc.trim()}
        </p>
      </div>
      <div class="border-t border-gray-100 pt-4 text-xs font-semibold text-[var(--color-tertiary)] uppercase tracking-wider">
        Acceso de Empleado
      </div>
    </div>
  </div>
</section>
