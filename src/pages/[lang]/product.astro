---
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductOverview from '../../components/Product/ProductOverview.astro';
import ProductEcosystem from '../../components/Product/ProductEcosystem.astro';
import ProductRoles from '../../components/Product/ProductRoles.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<BaseLayout title={t('product.title')}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <ProductOverview />
    <ProductEcosystem />
    <ProductRoles />
  </div>
</BaseLayout>