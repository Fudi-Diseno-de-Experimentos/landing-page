---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import Title from '../UI/Title.astro';
import Button from '../UI/Button.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="py-24 bg-[var(--color-primary)] relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 opacity-10">
    <svg class="absolute right-0 bottom-0 transform translate-x-1/3 translate-y-1/3 w-96 h-96" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <path fill="#FFFFFF" d="M42.7,-73.4C55.9,-65.8,67.6,-54.6,76.6,-41.5C85.6,-28.4,91.8,-14.2,91.8,0C91.8,14.2,85.6,28.4,76.6,41.5C67.6,54.6,55.9,65.8,42.7,73.4C29.4,81,14.7,85,-0.6,86.1C-15.8,87.1,-31.7,85.2,-44.7,77.4C-57.7,69.6,-67.9,56,-75.7,41.4C-83.4,26.7,-88.7,13.4,-88.7,0C-88.7,-13.4,-83.4,-26.7,-75.7,-41.4C-67.9,-56,-57.7,-69.6,-44.7,-77.4C-31.7,-85.2,-15.8,-87.1,-0.6,-86.1C14.7,-85,29.4,-81,42.7,-73.4Z" transform="translate(100 100)" />
    </svg>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <Title as="h2" class="text-3xl md:text-5xl font-bold text-white mb-8">
      {t('cta.title')}
    </Title>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <Button variant="inverted" href="#" class="text-lg px-8 py-3 !bg-white !text-[var(--color-primary)] hover:!bg-gray-100">{t('cta.startFree')}</Button>
      <Button variant="outlined" href="#" class="text-lg px-8 py-3 !border-white !text-white hover:!bg-white/10">{t('cta.bookDemo')}</Button>
    </div>
  </div>
</section