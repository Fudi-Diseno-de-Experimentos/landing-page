---
interface Props {
  variant?: 'primary' | 'secondary' | 'inverted' | 'outlined';
  href?: string;
  class?: string;
  target?: string;
  rel?: string;
}

const { variant = 'primary', href, class: className = '', target, rel } = Astro.props;

const baseClass = "px-6 py-2 rounded-md font-semibold transition-colors duration-200 label-text text-center inline-block cursor-pointer";
const variants = {
  primary: "bg-[var(--color-primary)] text-white hover:opacity-90",
  secondary: "bg-[var(--color-secondary)] text-[var(--color-neutral)] hover:bg-[var(--color-tertiary)]",
  inverted: "bg-[var(--color-neutral)] text-white hover:opacity-90",
  outlined: "border-2 border-[var(--color-tertiary)] text-[var(--color-neutral)] hover:border-[var(--color-primary)]"
};
---

{href ? (
  <a href={href} target={target} rel={rel} class={`${baseClass} ${variants[variant]} ${className}`}>
    <slot />
  </a>
) : (
  <button class={`${baseClass} ${variants[variant]} ${className}`}>
    <slot />
  </button>
)}