---
interface Props {
  videoId: string;
  title: string;
  class?: string;
}

const { videoId, title, class: className = '' } = Astro.props;
---

<div class={`relative w-full mx-auto max-w-4xl overflow-hidden rounded-2xl border border-white/20 bg-white p-2 shadow-xl hover:shadow-2xl hover:scale-[1.01] transition-all duration-300 ${className}`}>
  <!-- Aspect ratio wrapper -->
  <div class="relative w-full aspect-video rounded-xl overflow-hidden bg-gray-950">
    <iframe
      src={`https://www.youtube.com/embed/${videoId}`}
      title={title}
      class="absolute top-0 left-0 w-full h-full border-0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </div>
</div>
